{
  "name": "irodori-dashboard-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.standalone.config.ts",
    "build": "tsc --noEmit && npm run build:standalone && npm run build:launcher",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "build:launcher": "vite build --config vite.config.ts",
    "test": "NODE_ENV=test vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "motion": "^12.42.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
